{
  "entities": {
    "MidYearCheckin": {
      "title": "MidYearCheckin",
      "description": "Mid-year performance feedback data.",
      "type": "object",
      "properties": {
        "doing_well": { "type": "string" },
        "focus_to_grow": { "type": "string" },
        "leadership_mastery": { "type": "string" },
        "additional_notes": { "type": "string" },
        "submitted_at": { "type": "string", "format": "date-time" },
        "shared_at": { "type": "string", "format": "date-time" },
        "shared_by": { "type": "string" }
      }
    },
    "ManagerPrivateData": {
      "title": "ManagerPrivateData",
      "description": "Sensitive manager-only data stored in a subcollection.",
      "type": "object",
      "properties": {
        "performance_trending_rating": { "type": "string" },
        "promotion_readiness": { "type": "string", "enum": ["ready_next_year_end", "ready_next_mid_year", "reassess_next_year"] },
        "updated_at": { "type": "string", "format": "date-time" },
        "manager_email": { "type": "string", "format": "email" }
      }
    },
    "Employee": {
      "title": "Employee",
      "description": "An employee record with comprehensive HR data and performance feedback.",
      "type": "object",
      "properties": {
        "employee_name": { "type": "string" },
        "employee_email": { "type": "string", "format": "email" },
        "manager_email": { "type": "string", "format": "email" },
        "hrbp_email": { "type": "string", "format": "email" },
        "mid_year_checkin": { "$ref": "MidYearCheckin" },
        "status": { "type": "string", "enum": ["Pending", "Draft", "Submitted", "Shared", "Acknowledged"] },
        "updated_at": { "type": "string", "format": "date-time" },
        "acknowledged_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employee records."
    },
    "/employees/{employeeId}/manager_private/current": {
      "schema": "ManagerPrivateData",
      "description": "Private manager ratings and promotion readiness."
    }
  }
}
