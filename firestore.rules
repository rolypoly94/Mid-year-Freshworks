rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function email() {
      return request.auth.token.get('email', request.auth.token.get('email_address', '')).lower();
    }
    
    function isFreshworksEmployee() {
      return isAuthenticated() && email().matches("^.+@freshworks\\.com$");
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        email() == 'sumit.yadav@freshworks.com' ||
        exists(/databases/$(database)/documents/admins/$(email()))
      );
    }
    
    function isOwner(employeeEmail) {
      return isFreshworksEmployee() && email() == employeeEmail.lower();
    }

    function isValidMidYearCheckin(data, status) {
      return data is map &&
             data.key_contributions is string && (status == 'Pending' || status == 'Draft' || data.key_contributions.size() > 0) &&
             data.development_evolution is string && (status == 'Pending' || status == 'Draft' || data.development_evolution.size() > 0) &&
             (data.get('leadership_mastery', '') is string);
    }

    function isValidManagerPrivate(data) {
      return data is map &&
             data.performance_trending_rating is string &&
             data.performance_trending_rating in ['Exceptional Results', 'Exceeds Results', 'Delivers Full Results', 'Delivers Some Results', 'Does Not Deliver Results', ''] &&
             (data.get('promotion_readiness', null) == null || data.promotion_readiness == '' || data.promotion_readiness in ['ready_next_year_end', 'ready_next_mid_year', 'reassess_next_year']) &&
             (data.get('additional_notes', '') is string) &&
             data.manager_email is string &&
             data.get('hrbp_email', '') is string &&
             data.updated_at is string;
    }

    function isValidEmployee(data) {
      return data.employee_name is string && data.employee_name.size() > 0 &&
             data.employee_email is string && data.employee_email.size() > 0 &&
             data.manager_email is string && data.manager_email.size() > 0 &&
             data.status in ['Pending', 'Draft', 'Submitted', 'Shared', 'Acknowledged'] &&
             (!('mid_year_checkin' in data) || isValidMidYearCheckin(data.mid_year_checkin, data.status));
    }

    function isValidAuditEntry(data) {
      return data.employee_id is string &&
             data.actor_email is string &&
             data.actor_email == email() &&
             data.timestamp is string &&
             data.event_type in ['submit', 'acknowledge', 'shared', 'admin_override'];
    }

    match /employees/{employeeId} {
      // Admin can do anything
      allow read, write: if isAdmin();
      
      // Access Control Logic
      allow get: if isFreshworksEmployee() && (
        (isOwner(resource.data.employee_email) && (resource.data.status == 'Shared' || resource.data.status == 'Acknowledged')) ||
        resource.data.manager_email == email() ||
        resource.data.get('hrbp_email', '') == email()
      );

      // Employee can always get their own basic profile, but we restrict mid_year_checkin visibility in the app
      // For simplicity, we allow 'get' if they are owner OR manager OR hrbp.
      // But we strictly block 'Shared' status for owner in UI.
      // Here we refine the 'get' for owner to block viewing draft/submitted reviews.
      allow get: if isFreshworksEmployee() && (
        (isOwner(resource.data.employee_email) && (resource.data.status == 'Shared' || resource.data.status == 'Acknowledged')) ||
        resource.data.manager_email == email() ||
        resource.data.get('hrbp_email', '') == email()
      );

      allow list: if isAdmin() || (isFreshworksEmployee() && (
        resource.data.manager_email == email() ||
        resource.data.get('hrbp_email', '') == email()
      ));
      
      allow create: if isAdmin() || (isFreshworksEmployee() && 
                    request.resource.data.manager_email == email() && 
                    isValidEmployee(request.resource.data));
                    
      allow update: if isAdmin() || (isFreshworksEmployee() && (
                    // Manager update - only if not already shared/acknowledged (can edit after submit but before acknowledge)
                    (resource.data.manager_email == email() &&
                     resource.data.status != 'Acknowledged' &&
                     request.resource.data.manager_email == email() &&
                     isValidEmployee(request.resource.data))
                    ) || (
                    // Employee acknowledgement
                    isOwner(resource.data.employee_email) && 
                    resource.data.status == 'Shared' &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledged_at', 'status']) &&
                    request.resource.data.status == 'Acknowledged'
                    ));
                    
      allow delete: if isAdmin();
    }

    // Consolidate manager_private rules for collectionGroup support
    match /{path=**}/manager_private/{docId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        resource.data.manager_email == email() || 
        resource.data.get('hrbp_email', '') == email()
      );
      allow write: if isAdmin() || (isFreshworksEmployee() && (
        // path[1] is the parent employee document ID
        get(/databases/$(database)/documents/employees/$(path[1])).data.manager_email == email() &&
        isValidManagerPrivate(request.resource.data)
      ));
    }

    match /import_audit/{auditId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /employee_audit/{auditId} {
      allow read: if isAdmin() || (isFreshworksEmployee() && email() == resource.data.employee_id);
      allow create: if isFreshworksEmployee() && (isValidAuditEntry(request.resource.data) || isAdmin());
      allow update, delete: if false;
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated() && (email() == adminId.lower() || isAdmin());
      allow create: if isAdmin();
      allow delete: if isAdmin() && email() != adminId.lower();
      allow update: if false;
    }
  }
}
